# Clerk Auth
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (set in Clerk dashboard too)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin secret (shared with FastAPI backend for validate-key endpoint)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=change_me_to_a_long_random_secret

# Stripe
# Secret key from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from https://dashboard.stripe.com → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from https://dashboard.stripe.com → Products → (create Pro & API products) → Price ID
STRIPE_PRO_PRICE_ID=price_...
STRIPE_API_PRICE_ID=price_...
# Your app's public URL (for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://portal.costsignal.io
